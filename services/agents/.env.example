# Public hostname routed to the agents VM.
APP_SITE_ADDRESS=app.example.com
APP_HOSTNAME=app.example.com
ACME_EMAIL=admin@example.com

# App security.
APP_SECRET_KEY=change-me-to-a-long-random-value
APP_ALLOWED_ORIGINS=https://app.example.com
APP_ENV=production
AGENT_RUNTIME=adk

# Preferred cross-VM path: agents call the network MCP server.
MCP_SERVER_URL=https://mcp.example.com/mcp
MCP_CLIENT_TRANSPORT=streamable-http

# Direct Moodle fallback for local/dev or if MCP_SERVER_URL is unset.
MOODLE_BASE_URL=https://moodle.example.com
MOODLE_TOKEN=
MOODLE_REST_FORMAT=json

# LiteLLM provider settings used by Google ADK and the legacy OpenAI-compatible path.
# LITELLM_PROVIDER and LITELLM_MODEL become provider/model, for example openai/gpt-4o-mini.
LITELLM_BASE_URL=https://api.openai.com/v1
LITELLM_API_KEY=
LITELLM_PROVIDER=openai
LITELLM_MODEL=gpt-4o-mini
