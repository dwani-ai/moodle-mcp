# Public hostname routed to the MCP VM when network transport is enabled.
MCP_SITE_ADDRESS=mcp.example.com
MCP_HOSTNAME=mcp.example.com
MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=8000
ACME_EMAIL=admin@example.com

# Moodle Web Services endpoint on the Moodle VM.
MOODLE_BASE_URL=https://moodle.example.com
MOODLE_TOKEN=
MOODLE_REST_FORMAT=json
