# Public hostnames routed by Caddy.
DOMAIN=localhost
APP_HOSTNAME=app.localhost
MOODLE_HOSTNAME=moodle.localhost
MCP_HOSTNAME=mcp.localhost
ACME_EMAIL=admin@example.com

# Moodle installation.
MOODLE_DOWNLOAD_URL=https://packaging.moodle.org/stable405/moodle-4.5.4.tgz
MOODLE_PUBLIC_HOST=moodle.localhost
MOODLE_PUBLIC_SCHEME=http
MOODLE_BASE_URL=http://moodle
MOODLE_SITE_NAME=Moodle MCP
MOODLE_ADMIN_USERNAME=admin
MOODLE_ADMIN_PASSWORD=change-me
MOODLE_ADMIN_EMAIL=admin@example.com
MOODLE_DB_NAME=moodle
MOODLE_DB_USER=moodle
MOODLE_DB_PASSWORD=change-me
MOODLE_SSLPROXY=no

# Moodle Web Services token created after initial Moodle setup.
MOODLE_TOKEN=
MOODLE_REST_FORMAT=json

# MCP server settings.
MCP_TRANSPORT=streamable-http
MCP_SERVER_URL=http://mcp:8000/mcp
MCP_CLIENT_TRANSPORT=streamable-http

# LiteLLM provider settings used by Google ADK and the legacy OpenAI-compatible path.
LITELLM_BASE_URL=https://api.openai.com/v1
LITELLM_API_KEY=
LITELLM_PROVIDER=openai
LITELLM_MODEL=gpt-4o-mini

# App security.
APP_SECRET_KEY=change-me-to-a-long-random-value
APP_ALLOWED_ORIGINS=http://localhost,http://app.localhost
APP_ENV=local
AGENT_RUNTIME=adk
